                        <div style="margin-top: 24px; text-align: left">
                          <p style="margin: 0; line-height: 24px"></p>
                          <p style="margin: 0; line-height: 24px">
                            You can view more details about this subscription in your
                            <a href="{{business_subscription_page_link}}" style="color: #4045e1">Business Dashboard</a>
