  <body style="margin: 0; width: 100%; background-color: #f8fafc; padding: 0; -webkit-font-smoothing: antialiased; word-break: break-word">
    <div role="article" aria-roledescription="email" aria-label="📊 New Subscription: {{subscriber_name}} has subscribed to {{plan_name}}" lang="en">
      <div
