                          </p>
                          <p></p>
                          <p style="margin: 0; line-height: 24px">
                            If you have any questions about your subscription, feel free to reach out to our support team at
                            <a href="mailto:undefined" style="color: #4045e1">{{ support_email }}</a>
                            .
                          </p>
                        </div>
