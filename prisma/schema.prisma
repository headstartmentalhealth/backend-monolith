  reviews        Review[]
  subscription_plan   SubscriptionPlan?
  purchased_digital_products  PurchasedDigitalProduct[]
  digital_product_cart_items  CartItem[]  @relation("digital_product")
  cart_item   CartItem[]  @relation("cart_product")  
  physical_product    PhysicalProduct?  @relation("physical_product") 
  physical_product_cart_items   CartItem[] @relation("physical_product")

  @@index([category_id])
  @@index([business_id])
  @@index([creator_id])
  @@index([multimedia_id])
  @@map("products")
}

