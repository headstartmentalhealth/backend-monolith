  business_id             String      @db.VarChar(36)
  currency                String      @db.VarChar(3)
  currency_sign           String?     @db.VarChar(3)
  currency_url            String?
  creator_id              String?     @db.VarChar(36)
  created_at              DateTime    @default(now())
  updated_at              DateTime    @updatedAt
  deleted_at              DateTime?

  business                BusinessInformation?    @relation(fields: [business_id], references: [id], onDelete: Cascade)
  creator                 User?    @relation(fields: [creator_id], references: [id], onDelete: Cascade)

  @@unique([business_id, currency, currency_sign])
  @@map("business_product_enabled_currencies")
}

model PhysicalProduct {
  id                      String        @id @default(uuid())
  product_id              String        @unique @db.VarChar(36)
  sizes                   Json?
  colors                  Json?
  location                String
  stock                   Int
  type                    PhysicalProductType   @default(product)
  
  gender                  PhysicalProductGender
  estimated_production_time   Int?
  min_required            Int?
  created_at              DateTime            @default(now())
  updated_at              DateTime            @updatedAt
  deleted_at              DateTime?

  product                 Product?    @relation("physical_product", fields: [product_id], references: [id], onDelete: Cascade)
  media                   PhysicalProductMedia[]


  @@index([product_id])
  @@map("physical_products")
}

model PhysicalProductMedia {
  id                      String              @id @default(uuid())
  multimedia_id           String              @db.VarChar(36)
  physical_product_id     String              @db.VarChar(36)
  created_at              DateTime            @default(now())
  updated_at              DateTime            @updatedAt
  deleted_at              DateTime?

  multimedia              Multimedia?         @relation(fields: [multimedia_id], references: [id], onDelete: Cascade)
  physical_product        PhysicalProduct?    @relation(fields: [physical_product_id], references: [id], onDelete: Cascade)

  @@map("physical_product_media")
}

