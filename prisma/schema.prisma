  multimedia_zip_id  String?              @db.VarChar(36)

  /// Array of objects in this shape:
  /// e.g: [{ currency: "USD", price: 10.00, original_price: 15.00 }]
  other_currencies  Json?     
              
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt
  deleted_at     DateTime?

  cart_items     CartItem[]
  enrolled       EnrolledCourse[]
  modules        Module[]
  business_info  BusinessInformation? @relation(fields: [business_id], references: [id], onDelete: Cascade)
  category       ProductCategory?     @relation(fields: [category_id], references: [id], onDelete: Cascade)
  creator        User?                @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  multimedia     Multimedia?          @relation("multimedia", fields: [multimedia_id], references: [id], onDelete: Cascade)
  zip_file        Multimedia?          @relation("multimedia_zip_file", fields: [multimedia_zip_id], references: [id], onDelete: Cascade)
