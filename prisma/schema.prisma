  product_type   ProductType
  currency       String?     @default("NGN")
  quantity       Int
  price_at_time  Decimal     @db.Decimal(10, 2)
  created_at     DateTime    @default(now())
  deleted_at     DateTime?
  updated_at     DateTime    @updatedAt
  course_id      String?     @db.VarChar(36)
  digital_product_id      String?     @db.VarChar(36)
  ticket_tier_id          String?     @db.VarChar(36)
  subscription_plan_price_id String?     @db.VarChar(36)
  physical_product_id        String?     @db.VarChar(36)
  metadata            Json? 

  product             Product?    @relation("cart_product", fields: [product_id], references: [id], onDelete: Cascade)
  cart                Cart        @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  course              Product?    @relation(fields: [course_id], references: [id], onDelete: Cascade)
  digital_product         Product?    @relation("digital_product", fields: [digital_product_id], references: [id], onDelete: Cascade)
  ticket_tier         TicketTier? @relation(fields: [ticket_tier_id], references: [id], onDelete: Cascade)
