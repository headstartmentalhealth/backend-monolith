generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Log {
  id         String    @id @default(uuid())
  user_id    String?   @db.VarChar(36)
  action     Action
  entity     String
  entity_id  String?
  metadata   Json
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?
  user       User?     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("logs")
}

model RoleGroup {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  roles       Role[]

  @@index([name])
  @@map("role_groups")
}

model Role {
  id            String    @id @default(uuid())
  name          String    @unique
  role_group_id String
  description   String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  role_id       String    @unique
  deleted_at    DateTime?
  role_group    RoleGroup @relation(fields: [role_group_id], references: [id])
  users         User[]

  @@index([role_id])
  @@index([role_group_id])
  @@map("roles")
}

enum JoinedVia {
  IMPORT
  PURCHASE
  SOCIAL_MEDIA
  INVITATION
}

model User {
  id                       String                  @id @default(uuid())
  name                     String                  @db.VarChar(255)
  email                    String                  @unique @db.VarChar(320)
  password_hash            String?
  phone                    String?                 @unique @db.VarChar(20)
  is_email_verified         Boolean                 @default(false)
  is_phone_verified         Boolean                 @default(false)
  is_first_signup           Boolean                 @default(true)
  created_at               DateTime                @default(now())
  updated_at               DateTime                @updatedAt
  deleted_at               DateTime?
  role_identity            String?                 @db.VarChar(255)
  is_suspended             Boolean?                @default(false)
  suspended_by             String?                 @db.VarChar(36)
  suspended_at             DateTime?
  suspension_reason        String?                 @db.Text
  signin_option            String?                 @default("INTERNAL")
  alternative_phone        String?
  referral_source          String?

  billing_info             BillingInformation[]
  business_contacts        BusinessContact[]
  business_info            BusinessInformation[]
  cart                     Cart?
  coupon_usages            CouponUsage[]
  coupons                  Coupon[]
  courses                  Course[]
  email_verification       EmailVerification?
  enrolled_courses         EnrolledCourse[]
  logs                     Log[]
  module_contents          ModuleContent[]
  modules                  Module[]
  multimedia               Multimedia[]
  notification_devices     NotificationDevice[]
  notification_recipients  NotificationRecipient[]
  onboarding_status        OnboardingStatus[]
  otp                      Otp?
  password_resets          PasswordReset[]
  payments                 Payment[]
  product_categories       ProductCategory[]
  products                 Product[]
  profile                  Profile?
  purchased_tickets        PurchasedTicket[]
  rate_limits              RateLimit[]
  sessions                 Session[]
  social_logins            SocialLogin[]
  subscription_plan_prices SubscriptionPlanPrice[]
  subscription_plan_roles  SubscriptionPlanRole[]
  subscription_plans       SubscriptionPlan[]
  subscriptions            Subscription[]
  course_progress          UserCourseProgress[]
  role                     Role?                   @relation(fields: [role_identity], references: [id])
  instantNotifications     Notification[]          @relation("instant_notification_recipients")
  notifications             Notification[]
  notification_tokens       NotificationToken[]
  resources                 Resource[]

  // Relations
  initiated_chats          Chat[]       @relation("initiator_chats")
  buddy_chats              Chat[]       @relation("buddy_chats")
  sent_messages            ChatMessage[] @relation("sent_messages")
  received_messages        ChatMessage[] @relation("received_messages")
  chat_groups              ChatGroupMember[]
  created_chat_groups      ChatGroup[]
  withdraw_requests       WithdrawRequest[]
  paystack_recipient      PaystackRecipient?
  reviews                 Review[]
  kyc_reviewed            Kyc[]                   @relation("KycReviewer")
  kyc_user                Kyc[]                   @relation("KycUser")
  purchased_digital_products            PurchasedDigitalProduct[]
  currency_rate_created                 CurrencyRate[]           
  allowed_currencies_created            AllowedCurrency[]
  business_account_currencies_created   BusinessAccountCurrency[]
  business_product_enabled_currencies_created   BusinessProductEnabledCurrency[]
  blog_posts                BlogPost[]

  @@index([email])
  @@index([phone])
  @@index([role_identity])
  @@map("users")
}

model Profile {
  id              String    @id @default(uuid())
  user_id         String    @unique @db.VarChar(36)
  profile_picture  String?   @db.VarChar(2048)
  address         String?   @db.VarChar(255)
  bio             String?
  date_of_birth   DateTime?
  gender          Gender?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?
  country         String?   @db.VarChar(255)
  state           String?   @db.VarChar(255)
  country_code    String?   @default("NG") @db.Char(2)
  country_dial_code String? 
  user            User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("profile")
}

model Session {
  id            String    @id @default(uuid())
  user_id       String    @db.VarChar(36)
  session_token String    @unique @db.VarChar(255)
  expires_at    DateTime
  created_at    DateTime  @default(now())
  deleted_at    DateTime?
  updated_at    DateTime  @updatedAt
  user          User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("sessions")
}

model PasswordReset {
  id         String    @id @default(uuid())
  user_id    String    @db.VarChar(36)
  token      String    @unique @db.VarChar(255)
  expires_at DateTime
  created_at DateTime  @default(now())
  deleted_at DateTime?
  updated_at DateTime  @updatedAt
  user       User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("password_resets")
}

model RateLimit {
  id            String    @id @default(uuid())
  user_id       String?   @db.VarChar(36)
  ip_address    String    @db.VarChar(45)
  attempt_count Int       @default(0)
  last_attempt  DateTime  @default(now())
  deleted_at    DateTime?
  createdAt     DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  user          User?     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("rate_limits")
}

model SocialLogin {
  id          String    @id @default(uuid())
  user_id     String    @db.VarChar(36)
  provider    Provider?
  provider_id String    @unique
  createdAt   DateTime  @default(now())
  deleted_at  DateTime?
  updated_at  DateTime  @updatedAt
  user        User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("social_logins")
}

model EmailVerification {
  id                 String    @id @default(uuid())
  user_id            String    @unique @db.VarChar(36)
  verification_token String?    @unique
  expires_at         DateTime?  @db.Timestamptz(6)
  is_verified        Boolean   @default(false)
  created_at         DateTime  @default(now())
  deleted_at         DateTime?
  updated_at         DateTime  @updatedAt
  user               User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("email_verifications")
}

model OnboardingStatus {
  id           String              @id @default(uuid())
  user_id      String              @db.VarChar(36)
  current_step Int                 @default(1)
  is_completed Boolean             @default(false)
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt
  deleted_at   DateTime?
  business_id  String              @unique @db.VarChar(36)
  onboard_processes Json?
  business     BusinessInformation @relation(fields: [business_id], references: [id])
  user         User                @relation(fields: [user_id], references: [id])

  @@unique([user_id, business_id])
  @@index([user_id])
  @@index([business_id])
  @@map("onboarding_status")
}

model BusinessInformation {
  id                 String             @id @default(uuid())
  user_id            String             @db.VarChar(36)
  business_name      String             @unique @db.VarChar(255)
  business_size      BusinessSize
  business_slug      String?            @db.VarChar(36)
  business_description  String?
  timeline           String             @default("Africa/Lagos") @db.VarChar(100)
  logo_url           String?            @db.VarChar(2048)
  industry           String             @db.VarChar(255)
  working_hours      String?            @db.VarChar(255)
  location           String?            @db.VarChar(255)
  scope              String?            @db.VarChar(255)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  deleted_at         DateTime?
  country            String?            @default("Nigeria") @db.VarChar(255)
  state              String?            @db.VarChar(255)
  country_code       String?            @default("NG") @db.Char(2)
  social_media_handles  Json?
  enable_special_offer  Boolean?

  business_contacts  BusinessContact[]
  user               User               @relation(fields: [user_id], references: [id])
  business_wallet    BusinessWallet[]
  coupons            Coupon[]
  courses            Course[]
  module_contents    ModuleContent[]
  modules            Module[]
  multimedia         Multimedia[]
  notifications      Notification[]
  onboarding_status  OnboardingStatus?
  products           Product[]
  subscription_plans SubscriptionPlan[]
  withdrawal_account WithdrawalAccount?
  paystack_recipient           PaystackRecipient?
  withdraw_requests            WithdrawRequest[]
  kyc                          Kyc[]
  currencies         BusinessAccountCurrency[]
  product_currencies  BusinessProductEnabledCurrency[]
  payments            Payment[]
  blog_posts          BlogPost[]
  subscriptions       Subscription[]
  resources           Resource[]

  @@index([user_id])
  @@index([business_name])
  @@map("business_information")
}

model BusinessWallet {
  id               String              @id @default(uuid())
  business_id      String              @db.VarChar(36)
  balance          Decimal             @default(0.00) @db.Decimal(15, 2)
  previous_balance Decimal             @default(0.00) @db.Decimal(15, 2)
  currency         String              @default("NGN") @db.VarChar(3)
  currency_url     String?              
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
  deleted_at       DateTime?
  business         BusinessInformation @relation(fields: [business_id], references: [id])

  @@index([business_id])
  @@unique([business_id, currency])
  @@map("business_wallets")
}

model BusinessContact {
  id          String              @id @default(uuid())
  business_id String              @db.VarChar(36)
  user_id     String?             @db.VarChar(36)
  is_owner    Boolean             @default(false)
  joined_at   DateTime?           @default(now())
  status      MemberStatus        @default(pending)
  token       String?             @unique @db.VarChar(255)
  expires_at  DateTime?
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  deleted_at  DateTime?
  email       String              @db.VarChar(255)
  name        String?             @db.VarChar(255)
  role        String              @default("business-administrator")
  joined_via  JoinedVia?
  business    BusinessInformation @relation(fields: [business_id], references: [id])
  user        User?               @relation(fields: [user_id], references: [id])

  @@index([business_id])
  @@map("business_contacts")
}

model Otp {
  id         String    @id @default(uuid())
  user_id    String    @unique @db.VarChar(36)
  otp        String
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now())
  deleted_at DateTime?
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("otps")
}

model WithdrawalAccount {
  id             String              @id @default(uuid())
  business_id    String              @unique @db.VarChar(36)
  account_number String              @db.VarChar(255)
  account_type   String?              @db.VarChar(100)
  bank_name      String              @db.VarChar(255)
  bank_code      String?              @db.VarChar(255)
  routing_number String?             @db.VarChar(255)
  country        String              @default("Nigeria") @db.VarChar(255)
  country_code   String              @default("NG") @db.Char(2)
  currency       String              @default("NGN") @db.VarChar(255)
  recipient_code String?        
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt
  deleted_at     DateTime?
  business       BusinessInformation @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@map("withdrawal_accounts")
}

model SubscriptionPlan {
  id                       String                  @id @default(uuid())
  product_id               String?                 @unique @db.VarChar(255)
  name                     String                  @db.VarChar(255)
  description              String?
  cover_image              String?                 @db.VarChar(2048)
  business_id              String                  @db.VarChar(255)
  created_at               DateTime                @default(now())
  updated_at               DateTime                @updatedAt
  deleted_at               DateTime?
  creator_id               String                  @db.VarChar(255)
  payments                 Payment[]
  subscription_plan_prices SubscriptionPlanPrice[]
  subscription_plan_roles  SubscriptionPlanRole[]
  business                 BusinessInformation     @relation(fields: [business_id], references: [id], onDelete: Cascade)
  creator                  User                    @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  subscriptions            Subscription[]
  chat_groups              ChatGroup[]
  product                  Product?    @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([name, business_id])
  @@index([name])
  @@index([business_id])
  @@index([creator_id])
  @@index([product_id])
  @@map("subscription_plans")
}

model SubscriptionPlanPrice {
  id                   String             @id @default(uuid())
  subscription_plan_id String             @db.VarChar(255)
  price                Decimal            @db.Decimal(10, 2)
  currency             String             @default("NGN") @db.Char(3)
  creator_id           String             @db.VarChar(255)
  period               SubscriptionPeriod

  /// Array of objects in this shape:
  /// e.g: [{ currency: "USD", price: 10.00 }]
  other_currencies  Json?  

  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  deleted_at           DateTime?
  creator              User               @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  subscription_plan    SubscriptionPlan   @relation(fields: [subscription_plan_id], references: [id], onDelete: Cascade)
  cart_item            CartItem[]           

  @@index([subscription_plan_id])
  @@index([creator_id])
  @@map("subscription_plan_prices")
}

model SubscriptionPlanRole {
  id                   String           @id @default(uuid())
  subscription_plan_id String           @db.VarChar(255)
  creator_id           String           @db.VarChar(255)
  title                String           @db.VarChar(255)
  role_id              String           @db.VarChar(255)
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  deleted_at           DateTime?
  selected             Boolean          @default(false)
  creator              User             @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  subscription_plan    SubscriptionPlan @relation(fields: [subscription_plan_id], references: [id], onDelete: Cascade)

  @@unique([title, role_id])
  @@index([subscription_plan_id])
  @@index([creator_id])
  @@map("subscription_plan_roles")
}

model Coupon {
  id            String              @id @default(uuid())
  code          String              @unique
  type          CouponType
  creator_id    String              @db.VarChar(255)
  business_id   String              @db.VarChar(255)
  value         Float
  start_date    DateTime
  end_date      DateTime
  usage_limit   Int
  user_limit    Int
  min_purchase  Float
  is_active     Boolean             @default(true)
  created_at    DateTime            @default(now())
  updated_at    DateTime            @updatedAt
  deleted_at    DateTime?
  currency      String              @default("NGN") @db.Char(3)
  coupon_usages CouponUsage[]
  business      BusinessInformation @relation(fields: [business_id], references: [id], onDelete: Cascade)
  creator       User                @relation(fields: [creator_id], references: [id], onDelete: Cascade)

  @@unique([code, business_id])
  @@index([creator_id])
  @@index([business_id])
  @@map("coupons")
}

model CouponUsage {
  id               String    @id @default(uuid())
  coupon_id        String    @db.VarChar(255)
  user_id          String    @db.VarChar(255)
  discount_applied Decimal   @db.Decimal(10, 2)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?
  coupon           Coupon    @relation(fields: [coupon_id], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([coupon_id])
  @@index([user_id])
  @@map("coupon_usages")
}

model BillingInformation {
  id           String    @id @default(uuid())
  user_id      String    @db.VarChar(36)
  address      String
  state        String    @db.VarChar(255)
  apartment    String?   @db.VarChar(255)
  postal_code  String    @db.VarChar(11)
  city         String    @db.VarChar(255)
  country      String    @default("Nigeria") @db.VarChar(255)
  country_code String    @default("NG") @db.Char(2)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?
  selected     Boolean?  @default(false)
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@index([user_id])
  @@map("billing_information")
}

model Subscription {
  id                         String             @id @default(uuid())
  user_id                    String             @db.VarChar(36)
  plan_id                    String             @db.VarChar(36)
  plan_name_at_subscription  String             @db.VarChar(255)
  plan_price_at_subscription Decimal            @db.Decimal(10, 2)
  start_date                 DateTime
  end_date                   DateTime
  is_active                  Boolean            @default(true)
  payment_method             PaymentMethod
  billing_interval           SubscriptionPeriod
  business_id                String?            @db.VarChar(36)
  next_payment_date          DateTime?
  next_payment_amount        Decimal?            @db.Decimal(10, 2)
  auto_renew                 Boolean            @default(true)
  created_at                 DateTime           @default(now())
  updated_at                 DateTime           @updatedAt
  deleted_at                 DateTime?
  currency                   String             @default("NGN") @db.Char(3)
  grace_end_date             DateTime
  charge_auth_code           String?            @db.VarChar(255)
  subscription_plan          SubscriptionPlan   @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  user                       User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subscription_payments      SubscriptionPayment[]

  business_info                    BusinessInformation?   @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([plan_id])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id                         String             @id @default(uuid())
  subscription_id            String?            @db.VarChar(255)
  payment_id                 String?            @db.VarChar(36)
  amount                     Decimal            @db.Decimal(10, 2)
  currency                   String             @default("NGN") @db.Char(3)
  created_at                 DateTime           @default(now())
  updated_at                 DateTime           @updatedAt
  deleted_at                 DateTime?

  payment                    Payment?   @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  subscription               Subscription?   @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([subscription_id])
  @@map("subscription_payments")
}

model Payment {
  id                   String              @id @default(uuid())
  user_id              String?              @db.VarChar(36)
  business_id          String?             @db.VarChar(36)
  withdraw_request_id  String?             @db.VarChar(36)
  purchase_type        PurchaseType?       
  purchase_id          String?             @db.VarChar(36) /* Useful for subscription purchase */
  gross_amount         Decimal?             @db.Decimal(10, 2)
  amount               Decimal             @db.Decimal(10, 2)
  final_amount          Decimal?             @db.Decimal(10, 2)
  fee_amount           Decimal?             @db.Decimal(10, 2)
  fee_percent          Decimal?             @db.Decimal(10, 2)
  discount_applied     Decimal             @default(0.00) @db.Decimal(10, 2)
  payment_status       PaymentStatus
  transaction_id       String?             @unique @db.VarChar(255)
  access_code          String?             @unique @db.VarChar(255)
  payment_method       PaymentMethod?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt
  deleted_at           DateTime?
  billing_at_payment   Json?
  billing_id           String?             @db.VarChar(36)
  interval             SubscriptionPeriod?
  currency             String              @default("NGN") @db.Char(3)
  auto_renew           Boolean?            @default(false)
  is_renewal           Boolean?            @default(false)
  is_upgrade           Boolean?            @default(false)
  metadata             Json? /* Useful for withdrawals and whatnot */
  purchase             Json? /* Useful for other digital products purchase */
  transaction_type     TransactionType?
  payment_gateway_logs PaymentGatewayLog[]
  billing_info         BillingInformation? @relation(fields: [billing_id], references: [id], onDelete: Cascade)
  user                 User?                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subscription_plan    SubscriptionPlan?   @relation(fields: [purchase_id], references: [id], onDelete: Cascade, map: "subscription_fk")
  refunds              Refund[]
  business_info        BusinessInformation? @relation(fields: [business_id], references: [id], onDelete: Cascade)
  withdraw_request     WithdrawRequest?     @relation(fields: [withdraw_request_id], references: [id], onDelete: Cascade)
  subscription_payments        SubscriptionPayment[]
  purchased_digital_products  PurchasedDigitalProduct[]
  enrolled_courses     EnrolledCourse[]
  purchased_tickets    PurchasedTicket[]

  @@index([user_id])
  @@index([purchase_type])
  @@index([purchase_id])
  @@index([payment_status])
  @@map("payments")
}

model Refund {
  id            String        @id @default(uuid())
  payment_id    String        @db.VarChar(36)
  amount        Decimal       @db.Decimal(10, 2)
  reason        String?       @db.VarChar(255)
  status        RefundStatus
  type          RefundType    @default(REFUND)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  deleted_at    DateTime?
  refund_method PaymentMethod
  payment       Payment       @relation(fields: [payment_id], references: [id], onDelete: Cascade)

  @@index([payment_id])
  @@index([status])
  @@map("refunds")
}

model PaymentGatewayLog {
  id         String    @id @default(uuid())
  payment_id String
  event_type String    @db.VarChar(50)
  payload    Json
  metadata   Json?
  error      String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  payment    Payment   @relation(fields: [payment_id], references: [id], onDelete: Cascade)

  @@index([payment_id])
  @@index([event_type])
  @@map("payment_gateway_logs")
}

model Notification {
  id            String                 @id @default(uuid())
  title         String                 @db.VarChar(255)
  message       String
  status        Boolean                @default(true)
  read          Boolean                @default(false)
  icon_url      String?                @default("https://doexcess.com/favicon.ico")
  is_scheduled  Boolean                @default(false)
  business_id   String?                @db.VarChar(36)
  owner_id      String?                @db.VarChar(36)
  created_at    DateTime               @default(now())
  updated_at    DateTime               @updatedAt
  deleted_at    DateTime?
  type          NotificationType
  account_role  String?   // Some certain business admins of a business dir should see it.

  business      BusinessInformation?    @relation(fields: [business_id], references: [id])
  schedule_info ScheduledNotification?
  recipients    User[]                 @relation("instant_notification_recipients")
  owner         User?                  @relation(fields: [owner_id], references: [id])

  @@index([business_id])
  @@map("notifications")
}

model NotificationDevice {
  id          String                  @id @default(uuid())
  user_id     String                  @db.VarChar(36)
  device_type String
  push_token  String
  platform    PlatformType            @default(Firebase)
  created_at  DateTime                @default(now())
  updated_at  DateTime                @updatedAt
  deleted_at  DateTime?
  user        User                    @relation(fields: [user_id], references: [id])
